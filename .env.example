# -----------------------------------------------------------------------------
# Sentinel RFID Attendance System - Environment Variables
# Copy this file to .env and fill in production values.
# -----------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
POSTGRES_DB=attendance
DATABASE_URL=postgresql+asyncpg://sentinel:CHANGE_ME@db:5432/attendance

# Redis
REDIS_URL=redis://redis:6379/0

# JWT / Auth
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RFID / Scan
BOUNCE_WINDOW_SECONDS=2

# Cookie Security
# Set to true when serving over HTTPS (production)
COOKIE_SECURE=false

# Schema bootstrap (recommended false in production)
AUTO_CREATE_SCHEMA=false

# CORS
# Supports JSON array or comma-separated list.
CORS_ORIGINS=["http://localhost", "http://localhost:80"]

# Default Admin (auto-seeded on first startup)
FIRST_ADMIN_EMAIL=admin@company.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# Backward-compatible aliases (optional)
# DEFAULT_ADMIN_EMAIL=admin@company.com
# DEFAULT_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password
